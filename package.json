    "refresh-transfers": "node scripts/refresh-transfers.js",
    "refresh-data": "npm run refresh-alumni && npm run refresh-transfers",
    "typecheck": "tsc --noEmit"
  },
  "browserslist": {
    "production": [
      "last 2 Chrome versions",
      "last 2 Firefox versions",
      "last 2 Safari versions",
      "last 2 Edge versions"
