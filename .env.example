# Environment Variables Template
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend URL (update for production)
FRONTEND_URL=http://localhost:3000

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000

# Rate Limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Production Settings (uncomment for production)
# NODE_ENV=production
# PORT=5000
# FRONTEND_URL=https://yourdomain.com
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Scraper override flags
# Set to 'true' to force live scraping during local refresh runs.
# Production (NODE_ENV=production) and prerender (IS_PRERENDER=true)
# default to bundled fallback JSON in data/.
ALUMNI_SCRAPE_LIVE=
TRANSFER_SCRAPE_LIVE=

# Set to 'true' to enable the Puppeteer fallback when a request gets a 403.
# Defaults to off — on cloud-hosted infra (Render) the fallback hits the same
# blocked IP, so it adds latency without rescuing anything. Local dev with
# residential IP can set this to true if useful.
SCRAPER_PUPPETEER_FALLBACK=
